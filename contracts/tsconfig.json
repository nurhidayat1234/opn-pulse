{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declaration": true,
    "rootDir": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["./test", "./scripts", "./contracts"],
  "files": ["./hardhat.config.ts"]
}
